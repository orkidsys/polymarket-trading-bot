{
  "name": "polymarket-trading-bot",
  "version": "1.0.0",
  "description": "Copy trading bot for Polymarket with Supabase-backed trade history",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "health-check": "node dist/health-check.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["polymarket", "copy-trading", "trading-bot"],
  "license": "MIT",
  "dependencies": {
    "@polymarket/clob-client": "^5.7.0",
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}
