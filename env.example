# Copy to .env and fill in your values:
# cp env.example .env

# Traders to copy (comma-separated; find addresses on Polymarket leaderboard or Predictfolio)
USER_ADDRESSES=0x6a72f61820b26b1fe4d956e17b6dc2a1ea3033ee

# Your trading wallet (executes trades)
PROXY_WALLET=your_polygon_wallet_address
PRIVATE_KEY=your_private_key_without_0x_prefix

# Supabase (create project at supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Polygon RPC (Alchemy or Infura)
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Polymarket endpoints (do not change unless documented)
CLOB_HTTP_URL=https://clob.polymarket.com/
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws
DATA_API_URL=https://data-api.polymarket.com
USDC_CONTRACT_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174

# Copy trading config
TRADE_MULTIPLIER=1.0
FETCH_INTERVAL=1
MAX_SLIPPAGE_BPS=50

# Optional: tiered multipliers JSON array
# TIERED_MULTIPLIERS=[{"min_usd":0,"max_usd":100,"mult":1},{"min_usd":100,"max_usd":1000,"mult":1.5}]
